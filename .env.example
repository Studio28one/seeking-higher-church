# ─── Database ─────────────────────────────────────────────────────────────────
# Shared Postgres database (same as main seeking-higher app)
DATABASE_URL=postgresql://user:password@host:5432/seekinghigher?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret for signing JWT session tokens — use a long random string
SESSION_SECRET=change-me-to-a-long-random-secret

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@seekinghigher.church

# ─── Stripe (optional) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
